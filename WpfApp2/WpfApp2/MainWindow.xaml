<Window x:Class="WpfApp2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp2"
        mc:Ignorable="d"
        Title="Code 39" Height="450" Width="800">
    <Grid>
        
        <TextBlock Margin="0 20 0 0" Text="CODE 39" HorizontalAlignment="Center" FontSize="40" FontWeight="Bold"/>
        <StackPanel Margin="10 5 10 0" VerticalAlignment="Center">
            <TextBlock>Введите текст:</TextBlock>
            <TextBox x:Name="symbolsTBox" Margin="0 10 0 0"/>
            <Button Content="Получить штрих-код " Margin="0 10 0 0" Click="Button_Click"/>
            <Canvas x:Name="BarcodeCanvas" Background="White" Margin="0 20 0 0"  UseLayoutRounding="True" 
        SnapsToDevicePixels="True"/>
        </StackPanel>
    </Grid>
</Window>
