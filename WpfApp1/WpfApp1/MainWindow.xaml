<Window x:Class="Project2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:col="clr-namespace:System.Collections;assembly=mscorlib"
        xmlns:local="clr-namespace:Project2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>

        <StackPanel VerticalAlignment="Center">
            <Button x:Name="ButtonWork" Content="Работать" Margin="0 10 0 0" Click="ButtonWork_Click"/>
            <Button x:Name="ButtonInfo" Content="Справка" Margin="0 10 0 0" Click="ButtonInfo_Click"/>
            <Button x:Name="ButtonExit" Content="Выход" Margin="0 10 0 0" Click="ButtonExit_Click"/>
        </StackPanel>
        <StackPanel Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0 10 0 0">
                <Button x:Name="fileDataBtn" Content="Отобразить данные из файла" Margin="0 0 5 0" Click="fileDataBtn_Click"/>
                <Button x:Name="addDataBtn" Content="Добавить новую тему" Margin="0 0 5 0" Click="addDataBtn_Click"/>
                <Button Content="Удалить тему" Margin="0 0 5 0"/>
            </StackPanel>
            <ListView Name="topicList" Margin="0 10 0 0" ItemsSource="{DynamicResource ResourceKey=topics}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn DisplayMemberBinding="{Binding Path=StudentName}" Width="266">Имя студента</GridViewColumn>
                        <GridViewColumn DisplayMemberBinding="{Binding Path=TopicName}" Width="266">Тема</GridViewColumn>
                        <GridViewColumn DisplayMemberBinding="{Binding Path=Date}" Width="260">Дата</GridViewColumn>
                    </GridView>
                </ListView.View>
                <ListView.Resources>
                    <col:ArrayList x:Key="topics">

                    </col:ArrayList>
                </ListView.Resources>
            </ListView>
        </StackPanel>

        <Border x:Name="Overlay" 
                Background="#80000000" 
                Visibility="Collapsed"
                Panel.ZIndex="1"/>

        <Popup x:Name="AddPopup" 
               Placement="Center"
               PopupAnimation="Fade"
               AllowsTransparency="True"
               StaysOpen="False"
               IsOpen="{Binding IsPopupOpen, Mode=TwoWay}"
               Panel.ZIndex="2">

            <Border Background="White" 
                    BorderBrush="Gray" 
                    BorderThickness="1" 
                    CornerRadius="5"
                    Padding="20"
                    Width="350">

                <StackPanel>
                    <TextBlock Text="Добавить новую тему" 
                               FontSize="16" FontWeight="Bold" 
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="Имя студента:" Margin="0,0,0,5"/>
                    <TextBox x:Name="PopupStudentName" 
                             Height="25" Margin="0,0,0,10"/>

                    <TextBlock Text="Название темы:" Margin="0,0,0,5"/>
                    <TextBox x:Name="PopupTopicName" 
                             Height="25" Margin="0,0,0,10"/>

                    <TextBlock Text="Дата:" Margin="0,0,0,5"/>
                    <DatePicker x:Name="PopupDate" 
                        Height="25" Margin="0,0,0,20"
                        SelectedDate="{Binding Date, Mode=TwoWay}"
                        DisplayDateStart="2000-01-01"
                        DisplayDateEnd="2100-12-31">


                        <DatePicker.Resources>
                            <Style TargetType="DatePickerTextBox">
                                <Setter Property="Control.Template">
                                    <Setter.Value>
                                        <ControlTemplate>
                                            <TextBox x:Name="PART_TextBox" 
                                             Text="{Binding Path=SelectedDate, 
                                                      RelativeSource={RelativeSource AncestorType=DatePicker}, 
                                                      StringFormat='yyyy.MM.dd'}" />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DatePicker.Resources>
                    </DatePicker>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Сохранить" 
                                Width="100" Height="30" 
                                Margin="5"
                                Click="PopupSave_Click"/>
                        <Button Content="Отмена" 
                                Width="100" Height="30" 
                                Margin="5"
                                Click="PopupCancel_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>
        <Popup x:Name="initialPopup"
                PopupAnimation="Fade"
                AllowsTransparency="True"
                StaysOpen="False"
                IsOpen="{Binding IsPopupOpen, Mode=TwoWay}"
                Panel.ZIndex="2">
            <StackPanel>
                <Button x:Name="workBtn" Content="Работать"/>
                <Button x:Name="infoBtn" Content="Справка"/>
                <Button x:Name="exitBtn" Content="Выход"/>
            </StackPanel>
        </Popup>
    </Grid>
</Window>
