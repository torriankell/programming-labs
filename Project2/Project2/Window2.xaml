<Window x:Class="Project2.Window2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Project2"
        mc:Ignorable="d"
        Title="Window2" Height="450" Width="800">
    <Grid>
        <StackPanel>
            <WebBrowser x:Name="MyWebBrowser" VerticalAlignment="Stretch" MinHeight="600" />
            
            <Button x:Name="backBtn" Content="Назад" Click="backBtn_Click" VerticalAlignment="Bottom"/>
        </StackPanel>
    </Grid>
</Window>
