<Window x:Class="Project2.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:col="clr-namespace:System.Collections;assembly=mscorlib"
        xmlns:local="clr-namespace:Project2" d:DataContext="{d:DesignInstance Type=local:TopicViewModel}"
        mc:Ignorable="d"
        Title="Работа с темами" Height="500" Width="850"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center" 
                    Margin="10">
            <Button x:Name="executeComBtn"
                    Content="Выполнить команды из файла"
                     Margin="5" 
                    Padding="10 5"
                    Command="{Binding HandleFileWCommandsCommand}"/>
            <Button x:Name="fileDataBtn" 
                    Content="Отобразить данные из файла" 
                    Margin="5" 
                    Padding="10 5"
                    Command="{Binding LoadTopicCommand}"/>

            <Button x:Name="addDataBtn" 
                    Content="Добавить новую тему" 
                    Margin="5" 
                    Padding="10 5"
                    Command="{Binding OpenAddPopupCommand}"/>

            <Button x:Name="deleteTopicBtn" 
                    Content="Удалить тему" 
                    Margin="5" 
                    Padding="10 5"
                    Command="{Binding RemoveTopicCommand}"/>

            <Button x:Name="backBtn" 
                    Content="Назад" 
                    Margin="5" 
                    Padding="10 5"
                    Command="{Binding CloseMainWindowCommand}" 
                    CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>
        </StackPanel>


        <ListView Grid.Row="1" 
                  Name="topicList" 
                  Margin="10"
                  ItemsSource="{Binding Topics}"
                  SelectedItem="{Binding SelectedTopic, Mode=TwoWay}">


            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Имя студента" 
                                    Width="266" 
                                    DisplayMemberBinding="{Binding StudentName}"/>

                    <GridViewColumn Header="Тема" 
                                    Width="266" 
                                    DisplayMemberBinding="{Binding TopicName}"/>

                    <GridViewColumn Header="Дата" 
                                    Width="260" 
                                    DisplayMemberBinding="{Binding Date, StringFormat='yyyy.MM.dd'}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <Border x:Name="Overlay" 
                Grid.RowSpan="2"
                Background="#80000000" 
                Panel.ZIndex="1"
                Visibility="{Binding OverlayVisibility}"/>

        <Border Grid.Row="2"
        Margin="5"
        BorderBrush="Black" 
        BorderThickness="1" 
        CornerRadius="2" 
        Padding="0">
            <ListBox ItemsSource="{Binding LogEntries}"
             BorderThickness="0"
             Padding="0"
             HorizontalContentAlignment="Stretch">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="LightGray" 
                        BorderThickness="0,0,0,1" 
                        Padding="1,2">
                            <TextBlock Text="{Binding}" 
                               TextWrapping="Wrap"
                               FontSize="12"/>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Popup x:Name="AddPopup" 
               Placement="Center"
               PopupAnimation="Fade"
               AllowsTransparency="True"
               StaysOpen="False"
               IsOpen="{Binding IsAddPopupOpen}"
            Panel.ZIndex="2">

            <Border Background="White" 
                    BorderBrush="Gray" 
                    BorderThickness="1" 
                    CornerRadius="5"
                    Padding="20"
                    Width="350">

                <StackPanel>
                    <TextBlock Text="Добавить новую тему" 
                               FontSize="16" FontWeight="Bold" 
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="Имя студента:" Margin="0,0,0,5"/>
                    <TextBox x:Name="PopupStudentName" 
                             Height="25" Margin="0,0,0,10" Text="{Binding NewStudentName}"/>

                    <TextBlock Text="Название темы:" Margin="0,0,0,5"/>
                    <TextBox x:Name="PopupTopicName" 
                             Height="25" Margin="0,0,0,10" Text="{Binding NewTopicName}"/>

                    <TextBlock Text="Дата:" Margin="0,0,0,5"/>
                    <DatePicker x:Name="PopupDate" 
                                Height="25" Margin="0,0,0,20"
                                SelectedDate="{Binding NewDate, Mode=TwoWay}"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Сохранить" 
                                Width="100" Height="30" 
                                Margin="5"
                                Command="{Binding SaveNewTopicCommand}"/>
                        <Button Content="Отмена" 
                                Width="100" Height="30" 
                                Margin="5"
                                Command="{Binding CancelAddCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>